# BuildSphere Glass Panel Detection — CV Service
# Environment Configuration

# ── API Settings ───────────────────────────────────────────────
# IP Address / Host to bind the server to (0.0.0.0 for all interfaces)
HOST="0.0.0.0"
# Port for the FastAPI server
PORT=8000
# Enable debug mode (auto-reload, verbose logging)
DEBUG=True

# ── Model Settings ─────────────────────────────────────────────
# Path to the YOLOv8 weights file
MODEL_PATH="yolov8m.pt"
# Confidence threshold for glass panel detection (0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.35
# Non-Maximum Suppression (NMS) IoU threshold
NMS_IOU_THRESHOLD=0.45
# Flag to use generic COCO classes (for demo/fallback)
USE_PRETRAINED_COCO=True

# ── Gemini Integration ─────────────────────────────────────────
GEMINI_API_KEY="AIzaSyCt4QEmFSHCDnTYerUP7CZ7EuomrAz5TgQ"
